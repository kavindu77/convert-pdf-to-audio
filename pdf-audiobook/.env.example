# ─── BACKEND ────────────────────────────────────────────────
# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pdf_audiobook

# Redis (job queue)
REDIS_URL=redis://localhost:6379/0

# JWT Secret — generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_d2VsY29tZWQtcGFuZGEtNzkuY2xlcmsuYWNjb3VudHMuZGV2JA
CLERK_SECRET_KEY=sk_test_YxaqoNJ8zRFAMSUMpCiwiyFaWNz7enWO43PwFlCd44

# Google Cloud (Translation + TTS + Vision OCR)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-project-id

# Storage (choose one)
STORAGE_BACKEND=gcs                  # gcs | s3 | local
GCS_BUCKET_NAME=your-bucket-name
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# Optional: OpenAI TTS (higher quality voices)
OPENAI_API_KEY=sk-...

# Optional: ElevenLabs (premium voices)
ELEVENLABS_API_KEY=...

# Rate limiting
MAX_FREE_PAGES=5
MAX_STUDENT_PAGES=50
MAX_FILE_SIZE_MB=50

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── FRONTEND ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Groq API Key (AI Tools)
# GROQ_API_KEY is server-only. Never prefix with NEXT_PUBLIC.
GROQ_API_KEY=
